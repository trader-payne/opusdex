# OpusDex Configuration
# All values overridable via CLI args or environment variables.

# Models
CLAUDE_MODEL="opus"                    # claude --model
CLAUDE_EFFORT="high"                   # claude --effort
CODEX_MODEL="gpt-5.4"                 # codex -m
CODEX_EFFORT="xhigh"                  # codex -c model_reasoning_effort="xhigh"

# Tool paths
CLAUDE_BIN="/root/.local/bin/claude"
CODEX_BIN="/root/.nvm/versions/node/v25.8.1/bin/codex"

# Directories (relative to OPUSDEX_DIR)
OPUSDEX_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Behavior
AUTO_PLAN=false
AUTO_COMMIT=false
TEST_RETRY_LIMIT=3
REVIEW_RETRY_LIMIT=1

# YOLO mode flags
CODEX_YOLO_FLAG="--yolo"
