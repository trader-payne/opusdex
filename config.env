# OpusDex Configuration
# All values overridable via CLI args or environment variables.

# Models
CLAUDE_MODEL="${CLAUDE_MODEL:-opus}"                    # claude --model
CLAUDE_EFFORT="${CLAUDE_EFFORT:-high}"                  # claude --effort
CODEX_MODEL="${CODEX_MODEL:-gpt-5.4}"                   # codex -m
CODEX_EFFORT="${CODEX_EFFORT:-xhigh}"                   # codex -c model_reasoning_effort="xhigh"
GEMINI_MODEL="${GEMINI_MODEL:-gemini-3.1-pro-preview}" # gemini -m

# Tool paths
CLAUDE_BIN="${CLAUDE_BIN:-/root/.local/bin/claude}"
CODEX_BIN="${CODEX_BIN:-/root/.nvm/versions/node/v25.8.1/bin/codex}"
GEMINI_BIN="${GEMINI_BIN:-/root/.nvm/versions/node/v25.8.1/bin/gemini}"

# Directories (relative to OPUSDEX_DIR)
OPUSDEX_DIR="${OPUSDEX_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

# Behavior
AUTO_PLAN="${AUTO_PLAN:-false}"
AUTO_COMMIT="${AUTO_COMMIT:-false}"
AUTO_LIVE="${AUTO_LIVE:-false}"
TEST_RETRY_LIMIT="${TEST_RETRY_LIMIT:-3}"
REVIEW_RETRY_LIMIT="${REVIEW_RETRY_LIMIT:-1}"
LIVE_RETRY_LIMIT="${LIVE_RETRY_LIMIT:-3}"
LIVE_REVIEW_LIMIT="${LIVE_REVIEW_LIMIT:-2}"

# YOLO mode flags
CODEX_YOLO_FLAG="${CODEX_YOLO_FLAG:---yolo}"
GEMINI_YOLO_FLAG="${GEMINI_YOLO_FLAG:---yolo}"
